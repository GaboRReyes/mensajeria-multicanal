APP_NAME="Mensajeria Multicanal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Base de datos (Supabase - Session Pooler)
DB_CONNECTION=pgsql
DB_HOST=aws-1-us-east-2.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.your-project-ref
DB_PASSWORD=your-supabase-password
DB_SSLMODE=require

QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database

# SMTP (configurable según proveedor)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=postmaster@mg.ejemplo.com
MAIL_PASSWORD=your-mail-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@itcelaya.edu.mx"
MAIL_FROM_NAME="${APP_NAME}"

# WhatsApp Cloud API
WHATSAPP_PHONE_ID=000000000000
WHATSAPP_TOKEN=EAAG...
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_API_VERSION=v20.0

SANCTUM_STATEFUL_DOMAINS=localhost:3000

# Lanzar Mailpit local (alternativa moderna a MailHog)
docker run -d -p 1025:1025 -p 8025:8025 axllent/mailpit
 
